        "#| echo: true\n",
        "#| fig-cap: \"MindBoost User Research Results\"\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "insights = ['Daily check-ins\\nhighly useful', 'Therapist\\naccess', 'Willing to pay\\n€4.99+/month']\n",
        "values = [67.8, 67.6, 35.0]\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8, 4))\n",
        "bars = ax.barh(insights, values, color=['#1B6B7B', '#29CADE', '#A0A4A8'])\n",
        "ax.set_xlabel('Percentage (%)')\n",
        "ax.set_xlim(0, 100)\n",
        "for bar, val in zip(bars, values):\n",
        "    ax.text(val + 1, bar.get_y() + bar.get_height()/2, f'{val}%', va='center')\n",
        "plt.tight_layout()\n",
        "plt.show()"
